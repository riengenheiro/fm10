---
import { CHECKOUT_URL } from '../constants';
---

<section data-block-id="block-fm-precos-6"
         class="block-section section-content block-product-boxes-1 d-block pt-5 pt-md-6 pb-5 pb-md-6"
         id="block-precos"
         data-id="block-precos"
         data-block-type="product-boxes-1"
         style="background-color: #ffffff; background-size: cover;">
    <div class="block-container orbit-container-lg">
        <div class="pl-0 pr-0">
            <div class="row">
                <div class="col-lg-10 offset-lg-1">
                    <div class="block-headline large-h1 text-center mb-4"
                         style="color: var(--heading-font-color)">
                        <div class="large-h1"><span style="color: rgb(0, 0, 0)">Comece hoje — sem risco</span></div>
                    </div>
                </div>

                <div class="col-md-8 offset-md-2 col-lg-6 offset-lg-3">
                    <div class="card p-4 d-flex flex-column h-100" style="border: 2.5px solid #00C853; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,200,83,0.12);">
                        <p class="text-center mb-2" style="font-size:13px; letter-spacing:1px; font-weight:700; color:#00A63E; text-transform: uppercase;">Oferta de teste</p>
                        <h3 class="mb-3 mt-0 text-center" style="color: #000000; font-weight:800; font-size: 26px;">PLANO PROFISSIONAL</h3>
                        <p class="text-center mb-1" style="color:#777; font-size:18px;">
                            <del>De R$ 99,90</del>
                        </p>
                        <div class="text-center mt-0 mb-4" style="line-height:1;">
                            <span style="font-size:16px; color:#444; font-weight:600;">Por apenas</span><br>
                            <strong style="font-size:72px; color:#009624; font-weight:900; font-family:'Outfit',sans-serif; display:block; margin-top:5px;">R$ 10,00</strong>
                        </div>
                        <div class="mb-4" style="font-size:18px; line-height:1.6; color: #333;">
                            <p class="mb-3">✅ <strong>6 Créditos</strong> para gerar qualquer documento</p>
                            <p class="mb-3">✅ Vocabulário técnico correto e alinhado à BNCC</p>
                            <p class="mb-3">✅ Documentos editáveis em Word</p>
                            <p class="mb-3">✅ Funciona direto no seu WhatsApp</p>
                            <p class="mb-3">✅ 7 dias de garantia — risco zero</p>
                        </div>
                        <div class="text-center mt-auto">
                            <a class="btn btn-success btn-lg btn-block"
                               href={CHECKOUT_URL}
                               data-cta="checkout"
                               id="cta-profissional"
                               style="padding: 18px 20px; font-size: 22px; font-weight: 800; text-transform: uppercase; border-radius: 8px; background-color: #00C853; border-color: #009624; box-shadow: 0 4px 12px rgba(0, 200, 83, 0.3); border: none;">
                                Quero meus relatórios em 5 min →
                            </a>
                            <div class="trust-badges">
                                <i class="fas fa-lock"></i> Compra segura &nbsp;·&nbsp;
                                <i class="fas fa-bolt"></i> Acesso imediato
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
